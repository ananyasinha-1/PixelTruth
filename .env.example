# PixelTruth — Environment Variables
# Copy this file to .env and fill in the values before running the app.
# ─────────────────────────────────────────────────────────────────────

# ── Model ────────────────────────────────────────────────────────────
# Path to the local Keras model file (default: deepfake_detection_model.h5)
PIXELTRUTH_MODEL_PATH=deepfake_detection_model.h5

# URL from which to download the model if PIXELTRUTH_MODEL_PATH doesn't exist.
# Must be HTTPS. Leave blank to skip auto-download.
PIXELTRUTH_MODEL_URL=https://huggingface.co/Piyush-Sharma788/PixelTruth/resolve/main/deepfake_detection_model.h5

# SHA-256 hex digest of the model file. Used to verify download integrity.
# Run: sha256sum deepfake_detection_model.h5
# Leave blank to skip verification (not recommended for production).
PIXELTRUTH_MODEL_SHA256=

# ── API Security ─────────────────────────────────────────────────────
# Secret API key required in the X-API-Key header for all API calls.
# Leave blank to disable API key authentication (open access — dev only).
PIXELTRUTH_API_KEY=

# ── Rate Limiting ────────────────────────────────────────────────────
# slowapi format: "N/period" (e.g. "10/minute", "100/hour")
PIXELTRUTH_RATE_LIMIT=10/minute

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
PIXELTRUTH_CORS_ORIGINS=http://localhost:8501,http://localhost:8000

# ── History Database ─────────────────────────────────────────────────
# SQLite database file path for prediction history.
PIXELTRUTH_DB_PATH=pixeltruth_history.db

# ── Image Safety ─────────────────────────────────────────────────────
# Maximum pixel count (width × height) accepted. Default: 25 000 000 (25MP).
# Images exceeding this cap are rejected before decoding.
PIXELTRUTH_MAX_PIXELS=25000000
